{
  "name": "motogiathinh-backend",
  "version": "1.0.0",
  "private": true,
  "description": "MOTOGIATHINH / CENTERSAI CRM backend - REST API + static webapp serving",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
