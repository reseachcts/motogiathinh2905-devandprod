# Copy to .env and edit. .env is gitignored.

# REST server bind
PORT=3000
NODE_ENV=production

# DB file location (relative to backend/ or absolute path)
DB_PATH=./data/motogiathinh.db

# JWT signing secret. REQUIRED in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# JWT cookie name + lifetime in days
JWT_COOKIE=mgt_session
JWT_DAYS=14

# Default admin seeded into the DB if no accounts exist.
# Change immediately after first login.
SEED_ADMIN_EMAIL=admin@motogiathinh.centersai
SEED_ADMIN_PASSWORD=admin

# CORS origins (comma-separated). Leave empty when API + webapp share an origin.
CORS_ORIGINS=
